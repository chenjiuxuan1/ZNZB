{
  "country": {
    "code": "CN",
    "name": "中国",
    "timezone": "Asia/Shanghai"
  },
  "grafana": {
    "dashboardUrl": "",
    "token": "${GRAFANA_SERVICE_ACCOUNT_TOKEN}",
    "cookie": "${GRAFANA_COOKIE}",
    "username": "${GRAFANA_BASIC_AUTH_USER}",
    "password": "${GRAFANA_BASIC_AUTH_PASSWORD}",
    "requestTimeoutSeconds": 20
  },
  "browserAuth": {
    "enabled": true,
    "headless": true,
    "apiHeadless": true,
    "loginTimeoutSeconds": 45,
    "storageStateFile": ".state/grafana-storage-state.cn.json",
    "userDataDir": ".state/chrome-profile-cn",
    "executablePath": "/Applications/Google Chrome.app/Contents/MacOS/Google Chrome"
  },
  "timeRange": {
    "from": "now-7d",
    "to": "now"
  },
  "rules": []
}
