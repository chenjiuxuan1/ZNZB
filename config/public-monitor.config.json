{
  "builtInChecks": {
    "queryError": false,
    "noData": false,
    "emptyMetrics": true
  },
  "ruleDefaults": {
    "requiredDatePresent": {
      "autoDetectCadence": true,
      "cadenceLookbackDays": 130,
      "cadenceMinIntervals": 3,
      "cadenceMinConfidence": 0.75,
      "cadenceMaxIntervalDays": 31,
      "cadenceMaxIntervalMonths": 3
    }
  },
  "cadenceObservation": {
    "retentionDays": 400,
    "maxEventsPerCard": 500,
    "graceMinutes": 120,
    "holidayDates": {}
  },
  "alerts": {
    "channel": "tv",
    "webhookUrl": "${TV_ALERT_WEBHOOK_URL}",
    "botId": "${TV_ALERT_BOT_ID}",
    "textField": "message",
    "sendWhenHealthy": true,
    "maxAnomalies": 50
  },
  "gateway": {
    "enabled": false,
    "baseUrl": "${BI_GATEWAY_BASE_URL}",
    "token": "${BI_GATEWAY_TOKEN}",
    "dashcardPath": "/api/bi-monitor/metabase/public-dashcard-json",
    "requestTimeoutSeconds": 60
  },
  "dataQuality": {
    "enabled": true,
    "countriesFile": "./config/countries.config.json",
    "panelTitlePattern": "当前异常数|异常数|current\\s*anomal",
    "aggregation": "sum",
    "requestTimeoutSeconds": 20
  },
