      ],
      "timezone": "dashboard",
      "minAbsDelta": 0.003,
      "maxAnomaliesPerCard": 10,
      "maxDateGapDays": 1,
      "maxAbsDelta": 0.15,
      "valueFormat": "percent"
    },
