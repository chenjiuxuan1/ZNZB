{
  "builtInChecks": {
    "queryError": false,
    "noData": false
  },
  "alerts": {
    "channel": "tv",
    "webhookUrl": "${TV_ALERT_WEBHOOK_URL}",
    "botId": "${TV_ALERT_BOT_ID}",
    "textField": "message",
    "sendWhenHealthy": true,
    "maxAnomalies": 50
  },
  "gateway": {
    "enabled": false,
    "baseUrl": "${BI_GATEWAY_BASE_URL}",
    "token": "${BI_GATEWAY_TOKEN}",
    "dashcardPath": "/api/bi-monitor/metabase/public-dashcard-json",
    "requestTimeoutSeconds": 60
  },
  "dataQuality": {
    "enabled": true,
    "countriesFile": "./config/countries.config.json",
    "panelTitlePattern": "当前异常数|异常数|current\\s*anomal",
    "aggregation": "sum",
    "requestTimeoutSeconds": 20
  },
  "rules": [
    {
      "type": "requiredDatePresent",
      "dashboardTitle": "OKR",
      "cardTitles": [
        "转化漏斗",
        "规模",
        "还款7日复借率",
        "单笔件均",
        "放款件数",
        "放款金额",
        "进件通过率",
        "进件规模",
        "成本"
      ],
      "dateColumn": "统计日期",
      "timezone": "dashboard",
      "requiredLagDays": 0,
      "exclude": [
        {
          "countryCode": "PK",
          "cardTitles": [
            "进件通过率",
            "进件规模",
            "规模",
            "转化漏斗",
            "成本"
          ]
        },
        {
          "countryCode": "PH",
          "cardTitles": [
            "还款7日复借率",
            "进件通过率",
            "进件规模"
          ]
        }
      ]
    },
    {
      "type": "requiredDatePresent",
      "countryCode": "PK",
      "dashboardTitle": "OKR",
      "cardTitles": [
        "进件通过率",
        "进件规模",
        "规模",
        "转化漏斗",
        "成本"
      ],
      "dateColumn": "统计日期",
      "timezone": "dashboard",
      "requiredLagDays": 1,
      "context": "PK特殊口径：D-1更新"
    },
    {
      "type": "requiredDatePresent",
      "countryCode": "PH",
      "dashboardTitle": "OKR",
      "cardTitles": [
        "还款7日复借率",
        "进件通过率",
        "进件规模"
      ],
      "dateColumn": "统计日期",
      "timezone": "dashboard",
      "requiredLagDays": 1,
      "context": "PH特殊口径：D-1更新"
    },
    {
      "type": "requiredDatePresent",
      "dashboardTitle": "OKR",
      "cardTitlePattern": "^费率",
      "dateColumn": "统计日期",
      "timezone": "dashboard",
      "requiredLagDays": 1
    },
    {
      "type": "requiredDatePresent",
      "dashboardTitle": "核心链路准实时监控",
      "cardTitlePattern": "^(新客|老客)-",
      "timezone": "dashboard",
      "requiredLagDays": 0
    },
    {
      "type": "requiredDatePresent",
      "dashboardTitle": "新客转化率(注册~放款)",
      "cardTitles": [
        "整体趋势",
        "规模&转化",
        "分app趋势",
        "分app规模&转化"
      ],
      "dateColumn": "注册日期",
      "timezone": "dashboard",
      "requiredLagDays": 0
    },
    {
      "type": "requiredDatePresent",
      "dashboardTitle": "放款统计",
      "cardTitles": [
        "每日放款统计",
        "GMV&笔数",
        "平均期限-天数 by 用户类型",
        "件均 by 用户类型"
      ],
      "dateColumn": "放款日期",
      "timezone": "dashboard",
      "requiredLagDays": 0
    },
    {
      "type": "requiredDatePresent",
      "dashboardTitle": "放款统计",
      "cardTitlePattern": "费率",
      "dateColumn": "放款日期",
      "timezone": "dashboard",
      "requiredLagDays": 1
    },
    {
      "type": "requiredDatePresent",
      "dashboardTitles": [
        "每期逾期率by日期",
        "每期逾期率"
      ],
      "cardTitles": [
        "每期逾期率",
        "每期逾期率-表"
      ],
      "dateColumn": "统计日期",
      "timezone": "dashboard",
      "requiredLagDays": 0,
      "context": "统计口径=到期日期",
      "exclude": [
        {
          "countryCode": "PK"
        }
      ],
      "parameters": [
        {
          "id": "c28a0a",
          "type": "string/=",
          "target": [
            "variable",
            [
              "template-tag",
              "grant_due"
            ]
          ],
          "value": [
            "到期日期"
          ]
        }
      ]
    },
    {
      "type": "requiredDatePresent",
      "countryCode": "PK",
      "dashboardTitles": [
        "每期逾期率by日期",
        "每期逾期率"
      ],
      "cardTitles": [
        "每期逾期率",
        "每期逾期率-表"
      ],
      "dateColumn": "统计日期",
      "timezone": "dashboard",
      "requiredLagDays": 1,
      "context": "PK特殊口径：统计口径=到期日期，D-1更新",
      "parameters": [
        {
          "id": "c28a0a",
          "type": "string/=",
          "target": [
            "variable",
            [
              "template-tag",
              "grant_due"
            ]
          ],
          "value": [
            "到期日期"
          ]
        }
      ]
    },
    {
      "type": "requiredDatePresent",
      "dashboardTitle": "核心指标概览",
      "cardTitles": [
        "未还占比",
        "滚动回款率"
      ],
      "dateColumn": "到期日期",
      "timezone": "dashboard",
      "requiredLagDays": 1,
      "parameters": [
        {
          "id": "52b3c4e6",
          "type": "string/=",
          "target": [
            "variable",
            [
              "template-tag",
              "date_type"
            ]
          ],
          "value": [
            "日"
          ]
        }
      ]
    },
    {
      "type": "completeDayChange",
      "dashboardTitle": "OKR",
      "cardTitle": "转化漏斗",
      "dateColumn": "统计日期",
      "columns": [
        "注册~进件",
        "进件~通过",
        "通过~放款",
        "注册~放款"
      ],
      "timezone": "dashboard",
      "minAbsDelta": 0.003,
      "maxAnomaliesPerCard": 10,
      "maxDateGapDays": 1,
      "maxAbsDelta": 0.15,
      "valueFormat": "percent"
    },
    {
      "type": "completeDayChange",
      "dashboardTitle": "OKR",
      "cardTitles": [
        "入催率",
        "进件通过率",
