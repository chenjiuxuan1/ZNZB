        "launch_num",
        "reg_cnt",
        "ocr_num"
      ],
      "timezone": "dashboard",
      "startTime": "00:00",
      "intervalMinutes": 30,
      "allowedDelayMinutes": 60,
      "expectedTimePointSource": "previousDay",
      "ignoreDimensionColumns": [
        "开始时间"
      ],
      "maxAnomaliesPerCard": 8
    },
    {
      "type": "intradayTimePointChange",
      "dashboardTitle": "核心链路准实时监控",
