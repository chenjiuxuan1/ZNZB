      "minAbsDelta": 0.003,
      "maxAnomaliesPerCard": 10,
      "maxDateGapDays": 1,
      "maxAbsDelta": 0.15,
      "valueFormat": "percent"
    },
    {
      "type": "completeDayChange",
      "dashboardTitle": "OKR",
      "cardTitles": [
        "规模",
        "单笔件均",
        "放款件数",
        "放款金额",
        "进件规模",
        "成本"
      ],
      "dateColumn": "统计日期",
      "columnPattern": "数|量|金额|件均|花费|成本",
      "timezone": "dashboard",
      "maxDropRate": 0.25,
      "maxRiseRate": 0.4,
      "correlatedChangeSuppressions": [
        {
          "columns": [
            "放款成本",
            "总花费",
            "注册成本"
          ],
          "sameDirection": true,
          "maxRelativeRateGap": 0.5
        }
      ],
      "maxAnomaliesPerCard": 12,
      "maxDateGapDays": 1
    },
    {
      "type": "completeDayChange",
      "dashboardTitle": "OKR",
      "cardTitles": [
        "入催数"
      ],
      "dateColumn": "统计日期",
      "columnPattern": "入催数",
      "timezone": "dashboard",
      "maxDropRate": 0.25,
      "maxRiseRate": 0.4,
      "minAbsDelta": 20,
      "minPrevious": 50,
      "maxAnomaliesPerCard": 12,
      "maxDateGapDays": 1
    },
    {
      "type": "completeDayChange",
      "dashboardTitle": "OKR",
      "cardTitlePattern": "^费率构成",
      "dateColumn": "统计日期",
      "columns": [
