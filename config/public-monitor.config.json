      "dateColumn": "统计日期",
      "columnPattern": "率|费率",
      "timezone": "dashboard",
      "minAbsDelta": 0.003,
      "maxAnomaliesPerCard": 12,
      "maxDateGapDays": 1,
      "maxAbsDelta": 0.15,
      "valueFormat": "percent"
    },
    {
      "type": "completeDayChange",
      "dashboardTitle": "OKR",
