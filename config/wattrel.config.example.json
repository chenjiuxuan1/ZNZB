    },
    "CN": {
      "database": {
        "host": "${WATTREL_CN_DB_HOST}",
        "port": "${WATTREL_CN_DB_PORT}",
        "user": "${WATTREL_CN_DB_USER}",
        "password": "${WATTREL_CN_DB_PASSWORD}",
        "database": "${WATTREL_CN_DB_NAME}",
        "charset": "utf8mb4"
      }
    }
  },
  "query": {
    "limit": 1000,
    "sql": "SELECT r.id, r.quality_id, r.name, r.type, r.`desc`, r.src_db, r.src_tbl, r.dest_db, r.dest_tbl, r.src_value, r.dest_value, r.diff, r.`begin`, r.`end`, r.result, r.status, r.src_error, r.dest_error, r.is_repaired, r.created_at, r.updated_at, s.src_sql AS src_sql, s.dest_sql AS dest_sql, s.msg_template AS msg_template FROM wattrel_quality_result r LEFT JOIN wattrel_quality_setting s ON r.quality_id = s.id WHERE r.result = 1 AND r.created_at >= DATE_SUB(NOW(), INTERVAL 3 DAY) ORDER BY r.created_at DESC LIMIT ?",
    "params": ["${limit}"]
  }
}
