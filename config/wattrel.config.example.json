{
  "enabled": true,
  "title": "Wattrel 数据质量巡检",
  "countries": {
    "INE": {
      "database": {
        "host": "${WATTREL_INE_DB_HOST}",
        "port": "${WATTREL_INE_DB_PORT}",
        "user": "${WATTREL_INE_DB_USER}",
        "password": "${WATTREL_INE_DB_PASSWORD}",
        "database": "${WATTREL_INE_DB_NAME}",
        "charset": "utf8mb4"
      }
    },
    "PH": {
      "database": {
        "host": "${WATTREL_PH_DB_HOST}",
        "port": "${WATTREL_PH_DB_PORT}",
        "user": "${WATTREL_PH_DB_USER}",
        "password": "${WATTREL_PH_DB_PASSWORD}",
        "database": "${WATTREL_PH_DB_NAME}",
        "charset": "utf8mb4"
      }
    },
    "TH": {
      "database": {
        "host": "${WATTREL_TH_DB_HOST}",
        "port": "${WATTREL_TH_DB_PORT}",
        "user": "${WATTREL_TH_DB_USER}",
        "password": "${WATTREL_TH_DB_PASSWORD}",
        "database": "${WATTREL_TH_DB_NAME}",
        "charset": "utf8mb4"
      }
    },
    "PK": {
      "database": {
        "host": "${WATTREL_PK_DB_HOST}",
        "port": "${WATTREL_PK_DB_PORT}",
        "user": "${WATTREL_PK_DB_USER}",
        "password": "${WATTREL_PK_DB_PASSWORD}",
        "database": "${WATTREL_PK_DB_NAME}",
