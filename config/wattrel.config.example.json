  "query": {
    "limit": 1000,
    "sql": "SELECT id, quality_id, name, type, `desc`, src_db, src_tbl, dest_db, dest_tbl, src_value, dest_value, diff, `begin`, `end`, result, status, src_error, dest_error, is_repaired, created_at, updated_at FROM wattrel_quality_result WHERE result = 1 AND created_at >= DATE_SUB(NOW(), INTERVAL 3 DAY) ORDER BY created_at DESC LIMIT ?",
